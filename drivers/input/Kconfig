if INPUT

menuconfig ZMK_BLE_HID_HOST
    bool "ZMK BLE HID Host (HOGP central) input device"
    default y
    depends on DT_HAS_ZMK_BLE_HID_HOST_ENABLED
    help
      Connect to a Bluetooth HID (HOGP / HID-over-GATT) pointing device as a
      BLE central, decode its HID reports, and republish them into ZMK's input
      subsystem so they can be remapped by zmk,input-listener / input-processors
      and output over USB/BLE by ZMK core.

      This module performs ingest only. Remapping and HID output stay in ZMK.

      Enabled automatically when a "zmk,ble-hid-host" devicetree node is present.

if ZMK_BLE_HID_HOST

# Standard Zephyr logging level knob -> CONFIG_ZMK_BLE_HID_HOST_LOG_LEVEL.
module = ZMK_BLE_HID_HOST
module-str = ZMK BLE HID Host
source "subsys/logging/Kconfig.template.log_config"

# Wheel-axis -> key taps. The wheel is a signed axis (left/right and up/down
# share one code, differing only by sign), which ZMK's stock code-only
# input-processors cannot split. When enabled, this module converts each tick
# into a tap of a distinct DPAD code so it can be remapped to a key/layer via
# zmk,input-processor-behaviors. Default n keeps the module a generic scroll
# source; the two axes are independent so you can key one and scroll the other.

config ZMK_BLE_HID_HOST_HWHEEL_AS_KEYS
    bool "Emit horizontal wheel (tilt) as DPAD_LEFT/RIGHT key taps"
    default n
    help
      Convert each horizontal-wheel tick into a tap of INPUT_BTN_DPAD_LEFT
      (tilt left) / INPUT_BTN_DPAD_RIGHT (tilt right) instead of an
      INPUT_REL_HWHEEL scroll event. Repurposes the axis: horizontal scroll is
      no longer emitted while enabled.

config ZMK_BLE_HID_HOST_WHEEL_AS_KEYS
    bool "Emit vertical wheel as DPAD_UP/DOWN key taps"
    default n
    help
      Convert each vertical-wheel tick into a tap of INPUT_BTN_DPAD_UP (up) /
      INPUT_BTN_DPAD_DOWN (down) instead of an INPUT_REL_WHEEL scroll event.
      Repurposes the axis: vertical scroll is no longer emitted while enabled.

# NOTE (M1): the BLE central / GATT-client requirements are NOT selected here
# yet. They are documented in README.md and must be enabled in the consuming
# zmk-config (CONFIG_BT_CENTRAL, CONFIG_BT_OBSERVER, CONFIG_BT_GATT_CLIENT,
# CONFIG_BT_GATT_AUTO_DISCOVER_CCC, a sufficient CONFIG_BT_MAX_CONN, etc.).
# Milestone M1 will revisit whether to `select` the additive ones here.

endif # ZMK_BLE_HID_HOST

endif # INPUT
